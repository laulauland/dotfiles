#!/usr/bin/env bash
# annotate — open the last Claude Code assistant message in a nvim tmux-popup
# alongside an empty reply buffer, then paste the reply back into the Claude
# Code input. Two buffers keeps markdown rendering on the assistant side while
# the reply side stays plain-text for typing.
#
# Intended to be invoked as `!annotate` from inside Claude Code running in tmux.

set -euo pipefail

EDITOR_CMD="${ANNOTATE_EDITOR:-nvim}"

die() { printf 'annotate: %s\n' "$*" >&2; exit 1; }

[ -n "${TMUX:-}" ] || die "must be run inside tmux (no TMUX env)"
command -v jq >/dev/null || die "jq not found in PATH"

# Capture the pane that launched us — that's the Claude Code pane. The popup
# will have its own pane id, so grab this one before opening it.
pane=$(tmux display-message -p -F '#{pane_id}')

project_dir="$HOME/.claude/projects/$(pwd | sed 's|/|-|g')"
[ -d "$project_dir" ] || die "no Claude Code project dir at $project_dir"

session_file=$(ls -t "$project_dir"/*.jsonl 2>/dev/null | head -n1 || true)
[ -n "$session_file" ] || die "no .jsonl session file in $project_dir"

last_text=$(jq -sr '
  [ .[]
    | select(.type == "assistant")
    | (.message.content // [])
    | select(type == "array")
    | map(select(.type == "text") | .text) | join("\n")
    | sub("^\\s+"; "") | sub("\\s+$"; "")
    | select(length > 0)
  ] | last // ""
' "$session_file")

[ -n "$last_text" ] || die "no assistant text found in $(basename "$session_file")"

tmpdir=$(mktemp -d -t annotate)
trap 'rm -rf "$tmpdir"' EXIT
assistant_file="$tmpdir/assistant.md"
reply_file="$tmpdir/reply.md"

printf '%s\n' "$last_text" >"$assistant_file"
: >"$reply_file"

# -o stacks the files horizontally (assistant on top, reply below). The +cmds
# run in order in whatever window is active at the time: mark the assistant
# buffer read-only, then hop down to the reply window.
tmux display-popup -E -e NVIM_IN_TMUX_POPUP=1 -w 90% -h 90% \
  "$EDITOR_CMD -o '$assistant_file' '$reply_file' \
    '+setlocal readonly nomodifiable' \
    '+wincmd j'"

reply=$(cat "$reply_file")

if [ -z "$(printf '%s' "$reply" | tr -d '[:space:]')" ]; then
  die "no reply written"
fi

# Paste into the Claude Code pane as a bracketed paste — keeps newlines intact
# without auto-submitting. Delay slightly so Claude Code's TUI has time to
# reattach its input handler after the external command returns.
buf="annotate-$$"
tmux set-buffer -b "$buf" -- "$reply"
( sleep 0.2 && tmux paste-buffer -p -b "$buf" -t "$pane" -d ) &
disown
