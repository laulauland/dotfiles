{
  "cleanupPeriodDays": 3650,
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "EnterPlanMode",
      "ExitPlanMode"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/notification-hook.sh"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/notification-hook.sh"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/notification-hook.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/git-to-jj-hook.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/jj-no-interactive-hook.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/pip-to-uv-hook.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/lau/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/worktree-create-hook.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/worktree-remove-hook.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/scripts/statusline-wrapper.sh"
  },
  "enabledPlugins": {
    "figma@claude-plugins-official": true,
    "sideshow@sideshow": true,
    "slack@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "sideshow": {
      "source": {
        "source": "github",
        "repo": "modem-dev/sideshow"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "autoCompactWindow": 250000,
  "pluginConfigs": {
    "sideshow@sideshow": {
      "options": {
        "sideshowUrl": "http://localhost:8228"
      }
    }
  },
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
