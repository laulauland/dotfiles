#!/usr/bin/env bash
set -euo pipefail

plugin_id() { printf '%s\n' "${HERDR_PLUGIN_ID:-laulauland.pando-workspace}"; }
herdr_bin() { printf '%s\n' "${HERDR_BIN_PATH:-herdr}"; }
pando_bin() {
  if command -v pando >/dev/null 2>&1; then printf 'pando\n'; return; fi
  if command -v pd >/dev/null 2>&1; then printf 'pd\n'; return; fi
  return 1
}

json_field() {
  local key=$1
  printf '%s' "${HERDR_PLUGIN_CONTEXT_JSON:-{}}" | jq -r --arg key "$key" '.[$key] // empty' 2>/dev/null || true
}

canonicalize() {
  realpath "$1"
}

require_pando() {
  if ! pando=$(pando_bin); then
    echo "error: pando not found on PATH" >&2
    exit 1
  fi
}

open_wizard() {
  local mode=${1:-workspace}
  local repo
  repo=$(json_field workspace_cwd)
  if [ -z "$repo" ]; then repo=$(json_field focused_pane_cwd); fi

  exec "$(herdr_bin)" plugin pane open \
    --plugin "$(plugin_id)" \
    --entrypoint wizard \
    --env "PANDO_SOURCE=$repo" \
    --env "PANDO_OPEN=$mode" \
    --focus
}

wizard() {
  require_pando
  local mode=${PANDO_OPEN:-workspace}
  local source=${PANDO_SOURCE:-}
  if [ -z "$source" ] || [ ! -d "$source" ]; then
    printf 'source path: '
    read -r source
  fi
  if [ -z "$source" ] || [ ! -d "$source" ]; then
    echo "error: source path does not exist: $source" >&2
    wait_to_close
    exit 1
  fi

  local default_name
  default_name="$(basename "$source")-$(date +%m%d-%H%M)"
  printf 'pando workspace name [%s]: ' "$default_name"
  read -r name
  name=${name:-$default_name}
  case "$name" in
    *[[:space:]]*|*/*|'')
      echo 'error: name must be non-empty and contain no whitespace or slash' >&2
      wait_to_close
      exit 1
      ;;
  esac

  echo "+ cd $source"
  echo "+ $pando create $name"
  local path
  if ! path=$(cd "$source" && "$pando" create "$name"); then
    echo "error: pando create failed" >&2
    wait_to_close
    exit 1
  fi

  if [ "$mode" = tab ]; then
    echo "+ $(herdr_bin) tab create --cwd $path --label pando:$name --focus"
    exec "$(herdr_bin)" tab create --cwd "$path" --label "pando:$name" --focus
  fi
  echo "+ $(herdr_bin) workspace create --cwd $path --label pando:$name --focus"
  exec "$(herdr_bin)" workspace create --cwd "$path" --label "pando:$name" --focus
}

wait_to_close() {
  printf '\npress enter to close...'
  read -r _ || true
}

pando_name_for_path() {
  local target=$1
  local name info path
  target=$(canonicalize "$target")
  "$pando" list | awk 'NR > 1 { print $1 }' | while IFS= read -r name; do
    [ -n "$name" ] || continue
    info=$("$pando" info "$name" --json 2>/dev/null || true)
    [ -n "$info" ] || continue
    path=$(printf '%s' "$info" | jq -r '.workspace_path // empty' 2>/dev/null || true)
    [ -n "$path" ] || continue
    if [ "$(canonicalize "$path")" = "$target" ]; then
      printf '%s\n' "$name"
      break
    fi
  done
}

remove_current() {
  require_pando
  local ctx_cwd pane_cwd workspace_cwd target name ws_id tab_id
  pane_cwd=$(json_field focused_pane_cwd)
  workspace_cwd=$(json_field workspace_cwd)
  ctx_cwd=${pane_cwd:-$workspace_cwd}
  if [ -z "$ctx_cwd" ]; then
    echo 'error: no focused pane or workspace cwd in Herdr context' >&2
    exit 1
  fi
  target=$(canonicalize "$ctx_cwd")
  name=$(pando_name_for_path "$target")
  if [ -z "$name" ]; then
    echo "error: $target is not a known pando workspace" >&2
    exit 1
  fi

  "$pando" remove "$name"

  ws_id=${HERDR_WORKSPACE_ID:-$(json_field workspace_id)}
  tab_id=${HERDR_TAB_ID:-$(json_field tab_id)}
  if [ -n "$workspace_cwd" ] && [ "$(canonicalize "$workspace_cwd")" = "$target" ] && [ -n "$ws_id" ]; then
    exec "$(herdr_bin)" workspace close "$ws_id"
  fi
  if [ -n "$tab_id" ]; then
    exec "$(herdr_bin)" tab close "$tab_id"
  fi
  echo "removed pando workspace: $name ($target)"
}

case "${1:-}" in
  open) open_wizard "${2:-workspace}" ;;
  wizard) wizard ;;
  remove) remove_current ;;
  *)
    echo 'usage: pando-workspace <open [workspace|tab] | wizard | remove>' >&2
    exit 2
    ;;
esac
