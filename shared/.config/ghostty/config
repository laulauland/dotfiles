# theme = xcodedarkhc
font-family = "Berkeley Mono"
adjust-cell-height = 25%
copy-on-select = clipboard
macos-non-native-fullscreen = true
macos-titlebar-style = transparent
shell-integration = fish
macos-icon="retro"
macos-icon-frame="beige"
shell-integration-features=ssh-env,ssh-terminfo,title,sudo
window-inherit-working-directory = true
quick-terminal-animation-duration = 0

# Follow Ghostty prerelease channel (required for newest features like key tables)
auto-update-channel = tip

clipboard-read = allow
clipboard-write = allow

# Keep shift+enter for Claude Code multiline input
#keybind = shift+enter=text:\x1b[200~\x0a\x1b[201~
keybind = alt+arrow_down=jump_to_prompt:+1
keybind = alt+arrow_up=jump_to_prompt:-1


theme = light:Alabaster, dark:USGC-RETICLE-IT

config-file = mode/normal
config-file = mode/tmux
config-file = mode/vim
