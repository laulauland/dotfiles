#!/usr/bin/env bash
set -euo pipefail

TARGET=${1:-laurynas@shire}
REMOTE_DIR=${DOTFILES_DIR:-/home/laurynas/Code/laulauland/dotfiles}

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)

ssh "$TARGET" "mkdir -p '$(dirname "$REMOTE_DIR")'"

rsync -az --delete \
	--exclude result \
	--exclude .direnv/ \
	--exclude .DS_Store \
	"$ROOT/" "$TARGET:$REMOTE_DIR/"

ssh -t "$TARGET" "cd '$REMOTE_DIR' && ./nixos/switch"
