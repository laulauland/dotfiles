#!/usr/bin/env bash
set -euo pipefail

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
HOST=$(hostname -s 2>/dev/null || hostname)
EXTRA_ARGS=()

if [ "${1:-}" = "--bootstrap" ]; then
	EXTRA_ARGS=(
		--option extra-substituters https://install.determinate.systems
		--option extra-trusted-public-keys cache.flakehub.com-3:hJuILl5sVK4iKm86JzgdXW12Y2Hwd5G07qKtHTOcDCM=
	)
	shift
fi

case "$HOST" in
shire)
	sudo nixos-rebuild "${EXTRA_ARGS[@]}" --flake "path:$ROOT#$HOST" switch "$@"
	;;
*)
	echo "NixOS host '$HOST' is not configured."
	echo "Add it under nixos/hosts/ and flake.nix."
	exit 1
	;;
esac
