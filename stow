#!/usr/bin/env bash
set -euo pipefail

OPERATING_SYSTEM=$(uname)
HOSTNAME=$(hostname -s 2>/dev/null || uname -n 2>/dev/null || echo unknown)

run_stow() {
	if ! command -v stow >/dev/null 2>&1; then
		echo "stow is not installed. Please install it first."
		exit 1
	fi

	stow \
		--verbose \
		--restow \
		--adopt \
		--no-folding \
		--ignore='node_modules' \
		--ignore='defaults' \
		--ignore='^\.local/share($|/)' \
		--ignore='^\.local/state($|/)' \
		--ignore='(^|/)\.config/fish/fish_variables$' \
		--ignore='(^|/)fish_variables$' \
		--target ~ \
		--dotfiles \
		"$@"
}

is_nixos() {
	[ -r /etc/os-release ] && grep -q '^ID=nixos$' /etc/os-release
}

case "$OPERATING_SYSTEM" in
Darwin)
	run_stow shared macos
	;;
Linux)
	if is_nixos; then
		echo "NixOS host '$HOSTNAME' is not stow-managed."
		echo "Use ./nixos/switch instead."
		exit 1
	elif [ -r /etc/os-release ] && grep -q '^ID=arch$' /etc/os-release; then
		run_stow shared arch
	else
		echo "This Linux host is not configured for stow deployment."
		exit 1
	fi
	;;
*)
	echo "Your operating system is not supported."
	exit 1
	;;
esac
