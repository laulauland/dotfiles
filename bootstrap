#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
OPERATING_SYSTEM=$(uname)
APPLY_DEFAULTS=0
CHANGE_SHELL=0
INSTALL_FAILED=0

while [ $# -gt 0 ]; do
	case "$1" in
	--defaults)
		APPLY_DEFAULTS=1
		shift
		;;
	--fish-shell)
		CHANGE_SHELL=1
		shift
		;;
	*)
		break
		;;
	esac
done

install_homebrew() {
	if command -v brew >/dev/null 2>&1; then
		eval "$(brew shellenv)"
		return
	fi

	if [ "$OPERATING_SYSTEM" != "Darwin" ]; then
		echo "Homebrew is not installed."
		exit 1
	fi

	echo "Homebrew install needs sudo once to create system directories."
	sudo -v

	echo "Installing Homebrew..."
	NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

	if [ -x /opt/homebrew/bin/brew ]; then
		eval "$(/opt/homebrew/bin/brew shellenv)"
	elif [ -x /usr/local/bin/brew ]; then
		eval "$(/usr/local/bin/brew shellenv)"
	fi
}

install_stow() {
	if command -v stow >/dev/null 2>&1; then
		return
	fi

	echo "Installing GNU Stow..."
	brew install stow
}

brew_install_lines() {
	local file=$1
	local mode=$2
	local package

	[ -f "$file" ] || return

	while IFS= read -r package || [ -n "$package" ]; do
		case "$package" in
		"" | \#*) continue ;;
		esac

		echo "Installing $mode: $package"
		if [ "$mode" = "cask" ]; then
			if ! brew install --cask "$package"; then
				echo "warning: failed to install cask: $package" >&2
				INSTALL_FAILED=1
			fi
		else
			if ! brew install "$package"; then
				echo "warning: failed to install formula: $package" >&2
				INSTALL_FAILED=1
			fi
		fi
	done <"$file"
}

brew_tap_lines() {
	local file=$1
	local tap

	[ -f "$file" ] || return

	while IFS= read -r tap || [ -n "$tap" ]; do
		case "$tap" in
		"" | \#*) continue ;;
		esac

		echo "Tapping Homebrew repository: $tap"
		if ! brew tap "$tap"; then
			echo "warning: failed to tap Homebrew repository: $tap" >&2
			INSTALL_FAILED=1
		fi
	done <"$file"
}

mas_install_lines() {
	local file=$1
	local app_id
	local app_name

	[ -f "$file" ] || return
	command -v mas >/dev/null 2>&1 || return

	while read -r app_id app_name || [ -n "$app_id" ]; do
		case "$app_id" in
		"" | \#*) continue ;;
		esac

		echo "Installing mas app: $app_id $app_name"
		if ! mas install "$app_id"; then
			echo "warning: failed to install mas app: $app_id $app_name" >&2
			INSTALL_FAILED=1
		fi
	done <"$file"
}

set_fish_shell() {
	local fish_path

	if ! fish_path=$(command -v fish); then
		echo "warning: fish is not installed; cannot change login shell" >&2
		INSTALL_FAILED=1
		return
	fi

	if [ "$SHELL" = "$fish_path" ]; then
		return
	fi

	if ! grep -qxF "$fish_path" /etc/shells; then
		echo "Adding $fish_path to /etc/shells"
		echo "$fish_path" | sudo tee -a /etc/shells >/dev/null
	fi

	echo "Changing login shell to $fish_path"
	chsh -s "$fish_path"
}

bootstrap_macos() {
	install_homebrew
	brew update
	install_stow
	brew_tap_lines "$REPO_ROOT/Tapfile"
	brew_install_lines "$REPO_ROOT/Brewfile" formula
	brew_install_lines "$REPO_ROOT/Caskfile" cask
	mas_install_lines "$REPO_ROOT/Masfile"

	if [ "$INSTALL_FAILED" -ne 0 ]; then
		echo "One or more packages failed to install; continuing with dotfiles." >&2
	fi

	if ! "$REPO_ROOT/stow"; then
		echo "warning: stow failed; continuing with remaining bootstrap steps" >&2
		INSTALL_FAILED=1
	fi

	if [ "$APPLY_DEFAULTS" -eq 1 ]; then
		echo "Applying macOS defaults..."
		if ! "$REPO_ROOT/macos/defaults"; then
			echo "warning: one or more macOS defaults failed to apply" >&2
			INSTALL_FAILED=1
		else
			echo "Applied macOS defaults."
		fi
	fi

	if [ "$CHANGE_SHELL" -eq 1 ]; then
		set_fish_shell
	fi

	exit "$INSTALL_FAILED"
}

case "$OPERATING_SYSTEM" in
Darwin)
	bootstrap_macos
	;;
Linux)
	if [ -r /etc/os-release ] && grep -q '^ID=nixos$' /etc/os-release; then
		exec "$REPO_ROOT/nixos/switch" "$@"
	fi

	"$REPO_ROOT/stow"
	;;
*)
	echo "Your operating system is not supported."
	exit 1
	;;
esac
